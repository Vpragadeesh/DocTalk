# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=DOCTALK

# Google Gemini API
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-pro

# Groq API (primary LLM)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic API (for Deep Search reasoning)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# JWT Secret
JWT_SECRET_KEY=your-super-secret-jwt-key

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ===========================================
# Deep Search Configuration
# ===========================================

# Enable/disable deep search feature
DEEP_SEARCH_ENABLED=true

# Default search depth: simple, moderate, deep
DEEP_SEARCH_DEPTH=moderate

# Maximum context tokens for deep search
DEEP_SEARCH_MAX_CONTEXT=30000

# Timeout in seconds
DEEP_SEARCH_TIMEOUT=30

# Cache TTL in seconds
DEEP_SEARCH_CACHE_TTL=3600

# ===========================================
# Reasoning Configuration
# ===========================================

# Model for reasoning (Claude recommended)
REASONING_MODEL=claude-sonnet-4-20250514

# Temperature for reasoning (lower = more focused)
REASONING_TEMPERATURE=0.3

# Maximum reasoning steps
REASONING_MAX_STEPS=5

# Cost limit per query in USD (optional)
REASONING_COST_LIMIT=0.50

# ===========================================
# Knowledge Graph Configuration
# ===========================================

# Enable knowledge graph feature
KNOWLEDGE_GRAPH_ENABLED=true

# Minimum concept relevance threshold
KG_CONCEPT_THRESHOLD=0.7

# ===========================================
# Performance Configuration
# ===========================================

# Enable caching for deep search
DEEP_SEARCH_CACHE_ENABLED=true

# Cache strategy: lru (least recently used)
DEEP_SEARCH_CACHE_STRATEGY=lru

# Enable parallel reasoning
PARALLEL_REASONING=true

# Enable streaming responses
STREAMING_ENABLED=true
